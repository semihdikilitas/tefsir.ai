    "imageUrl": "https://tefsir-ai-api.fly.dev/uploads/1784449352329-143289981.jpg",
    "category": "Duvar Kağıtları",
    "verseText": "Rabbiniz size: \"Bana dua edin, size icabet edeyim\" buyurdu.",
    "surahName": "Mü'min Suresi",
    "verseNumbers": "60",
    "isPremium": true,
    "createdAt": "2026-01-01T00:00:00.000Z",
    "thumbnailUrl": "https://tefsir-ai-api.fly.dev/uploads/1784449352329-143289981.jpg"
  },
  {
    "id": "11",
    "asset": "pexels-bernahanim_-1173268160-30809929.jpg",
    "imageUrl": "https://tefsir-ai-api.fly.dev/uploads/1784449353628-356493179.jpg",
    "category": "Duvar Kağıtları",
    "verseText": "Kulunu bir gece Mescid-i Haram'dan Mescid-i Aksâ'ya yürüten Allah her türlü noksandan münezzehtir.",
    "surahName": "İsrâ Suresi",
    "verseNumbers": "1",
    "isPremium": true,
    "createdAt": "2026-01-01T00:00:00.000Z",
    "thumbnailUrl": "https://tefsir-ai-api.fly.dev/uploads/1784449353628-356493179.jpg"
  },
  {
    "id": "12",
    "asset": "pexels-betty-30079555.jpg",
    "imageUrl": "https://tefsir-ai-api.fly.dev/uploads/1784449354518-875169352.jpg",
    "category": "Duvar Kağıtları",
    "verseText": "Doğu da Allah'ındır, batı da. Nereye dönerseniz Allah'ın yüzü oradadır.",
    "surahName": "Bakara Suresi",
    "verseNumbers": "115",
    "isPremium": true,
    "createdAt": "2026-01-01T00:00:00.000Z",
    "thumbnailUrl": "https://tefsir-ai-api.fly.dev/uploads/1784449354518-875169352.jpg"
  },
  {
    "id": "13",
    "asset": "pexels-beyza-emisen-1205168918-38135685.jpg",
    "imageUrl": "https://tefsir-ai-api.fly.dev/uploads/1784449355363-998996886.jpg",
    "category": "Duvar Kağıtları",
    "verseText": "Gökleri ve yeri yaratan, onların benzerini yaratmaya kadir değil midir?",
    "surahName": "Yâsîn Suresi",
    "verseNumbers": "81",
    "isPremium": true,
    "createdAt": "2026-01-01T00:00:00.000Z",
    "thumbnailUrl": "https://tefsir-ai-api.fly.dev/uploads/1784449355363-998996886.jpg"
  },
  {
    "id": "14",
    "asset": "pexels-beyza-emisen-1205168918-38281843.jpg",
    "imageUrl": "https://tefsir-ai-api.fly.dev/uploads/1784449356539-451905182.jpg",
    "category": "Duvar Kağıtları",
    "verseText": "Yeryüzünde, onları sarsmasın diye sabit dağlar yerleştirdik.",
    "surahName": "Enbiyâ Suresi",
    "verseNumbers": "31",
    "isPremium": true,
    "createdAt": "2026-01-01T00:00:00.000Z",
    "thumbnailUrl": "https://tefsir-ai-api.fly.dev/uploads/1784449356539-451905182.jpg"
  },
  {
    "id": "15",
    "asset": "pexels-brokenadmiral_-493491871-16013170.jpg",
    "imageUrl": "https://tefsir-ai-api.fly.dev/uploads/1784449357981-866758742.jpg",
    "category": "Duvar Kağıtları",
    "verseText": "Gökten su indiren O'dur. Her bitkiyi onunla bitirdik.",
    "surahName": "En'âm Suresi",
    "verseNumbers": "99",
    "isPremium": true,
    "createdAt": "2026-01-01T00:00:00.000Z",
    "thumbnailUrl": "https://tefsir-ai-api.fly.dev/uploads/1784449357981-866758742.jpg"
  },
  {
    "id": "16",
    "asset": "pexels-bugrahan-haksever-337114162-17561872.jpg",
    "imageUrl": "https://tefsir-ai-api.fly.dev/uploads/1784449358751-911330018.jpg",
    "category": "Duvar Kağıtları",
    "verseText": "Yeryüzüne bakmazlar mı, onda her güzel çiftten nice bitkiler yetiştirdik.",
    "surahName": "Şu'arâ Suresi",
    "verseNumbers": "7",
    "isPremium": true,
    "createdAt": "2026-01-01T00:00:00.000Z",
    "thumbnailUrl": "https://tefsir-ai-api.fly.dev/uploads/1784449358751-911330018.jpg"
  },
  {
    "id": "17",
    "asset": "pexels-catalin-todosia-876894548-29871574.jpg",
    "imageUrl": "https://tefsir-ai-api.fly.dev/uploads/1784449360461-354753665.jpg",
    "category": "Duvar Kağıtları",
    "verseText": "Göklerin ve yerin yaratılışında akıl sahipleri için deliller vardır.",
    "surahName": "Âl-i İmrân Suresi",
    "verseNumbers": "190",
    "isPremium": true,
    "createdAt": "2026-01-01T00:00:00.000Z",
    "thumbnailUrl": "https://tefsir-ai-api.fly.dev/uploads/1784449360461-354753665.jpg"
  },
  {
    "id": "18",
    "asset": "pexels-cigdem-i-seri-163348451-12811841.jpg",
    "imageUrl": "https://tefsir-ai-api.fly.dev/uploads/1784449361941-716315272.jpg",
    "category": "Duvar Kağıtları",
    "verseText": "Göğe bakmazlar mı, onu nasıl yükselttik ve süsledik.",
    "surahName": "Kâf Suresi",
    "verseNumbers": "6",
    "isPremium": true,
    "createdAt": "2026-01-01T00:00:00.000Z",
    "thumbnailUrl": "https://tefsir-ai-api.fly.dev/uploads/1784449361941-716315272.jpg"
  },
  {
    "id": "19",
    "asset": "pexels-ebuuyildiz-17793951.jpg",
    "imageUrl": "https://tefsir-ai-api.fly.dev/uploads/1784449362918-482406090.jpg",
    "category": "Duvar Kağıtları",
    "verseText": "Güneş de bir delildir onlara; kendi yörüngesinde akıp gider.",
    "surahName": "Yâsîn Suresi",
    "verseNumbers": "38",
    "isPremium": true,
    "createdAt": "2026-01-01T00:00:00.000Z",
    "thumbnailUrl": "https://tefsir-ai-api.fly.dev/uploads/1784449362918-482406090.jpg"
  },
  {
    "id": "20",
