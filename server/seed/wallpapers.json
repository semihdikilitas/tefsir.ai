    "imageUrl": "https://tefsir-ai-api.fly.dev/uploads/1784449363493-851578127.jpg",
    "category": "Duvar Kağıtları",
    "verseText": "Ay'a gelince, ona da menziller tayin ettik.",
    "surahName": "Yâsîn Suresi",
    "verseNumbers": "39",
    "isPremium": true,
    "createdAt": "2026-01-01T00:00:00.000Z",
    "thumbnailUrl": "https://tefsir-ai-api.fly.dev/uploads/1784449363493-851578127.jpg"
  },
