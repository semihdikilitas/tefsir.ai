[
  {
    "id": "1",
    "text": "Ameller ancak niyetlere göredir.",
    "source": "Buhârî, Bedü'l-Vahy, 1",
    "category": "İman & İhlas",
    "arabic": "إِنَّمَا الْأَعْمَالُ بِالنِّيَّاتِ"
  },
  {
    "id": "2",
    "text": "Müslüman, elinden ve dilinden güvende olunan kişidir.",
    "source": "Buhârî, Îmân, 4",
    "category": "Ahlak",
    "arabic": "الْمُسْلِمُ مَنْ سَلِمَ الْمُسْلِمُونَ"
  },
  {
    "id": "3",
    "text": "Kolaylaştırın, zorlaştırmayın; müjdeleyin, nefret ettirmeyin.",
    "source": "Buhârî, İlim, 11",
    "category": "Ahlak",
    "arabic": "يَسِّرُوا وَلَا تُعَسِّرُوا"
  },
  {
    "id": "4",
    "text": "Kendin için istediğini kardeşin için de istemedikçe iman etmiş olmazsın.",
    "source": "Buhârî, Îmân, 7",
    "category": "İman & İhlas",
    "arabic": "لَا يُؤْمِنُ أَحَدُكُمْ حَتَّى يُحِبَّ لِأَخِيهِ"
  },
  {
    "id": "5",
    "text": "Namaz dinin direğidir.",
    "source": "Beyhakî, Şuabü'l-Îmân",
    "category": "İbadet",
    "arabic": "الصَّلَاةُ عِمَادُ الدِّينِ"
  },
  {
    "id": "6",
    "text": "İlim öğrenmek her Müslümana farzdır.",
    "source": "İbn Mace, Mukaddime, 17",
    "category": "İlim",
    "arabic": "طَلَبُ الْعِلْمِ فَرِيضَةٌ"
  },
  {
    "id": "7",
    "text": "Allah sizin suretlerinize değil, kalplerinize bakar.",
    "source": "Müslim, Birr, 33",
    "category": "İman & İhlas",
    "arabic": "إِنَّ اللَّهَ لَا يَنْظُرُ إِلَى صُوَرِكُمْ"
  },
  {
    "id": "8",
    "text": "Merhamet etmeyene merhamet olunmaz.",
    "source": "Buhârî, Edeb, 18",
    "category": "Ahlak",
    "arabic": "مَنْ لَا يَرْحَمْ لَا يُرْحَمْ"
  },
  {
    "id": "9",
    "text": "Komşusu açken tok yatan bizden değildir.",
    "source": "Hakim, Müstedrek",
    "category": "Sosyal Hayat",
    "arabic": "مَا آمَنَ بِي مَنْ بَاتَ شَبْعَانَ"
  },
  {
    "id": "10",
    "text": "Tebessüm etmek sadakadır.",
    "source": "Tirmizi, Birr, 36",
    "category": "Ahlak",
    "arabic": "تَبَسُّمُكَ فِي وَجْهِ أَخِيكَ صَدَقَةٌ"
  },
  {
    "id": "11",
    "text": "Allah her işte ihsanı emretmiştir.",
    "source": "Müslim, Sayd, 57",
    "category": "Ahlak",
    "arabic": "إِنَّ اللَّهَ كَتَبَ الْإِحْسَانَ"
  },
  {
    "id": "12",
    "text": "Mizanda en ağır basacak şey güzel ahlaktır.",
    "source": "Tirmizi, Birr, 62",
    "category": "Ahlak",
    "arabic": "أَثْقَلُ فِي الْمِيزَانِ حُسْنُ الْخُلُقِ"
  },
  {
    "id": "13",
    "text": "Dua ibadetin özüdür.",
    "source": "Tirmizi, Deavât, 1",
    "category": "İbadet",
    "arabic": "الدُّعَاءُ مُخُّ الْعِبَادَةِ"
  },
  {
    "id": "14",
    "text": "İman etmedikçe cennete giremezsiniz.",
    "source": "Müslim, Îmân, 93",
    "category": "İman & İhlas",
    "arabic": "لَا تَدْخُلُونَ الْجَنَّةَ حَتَّى تُؤْمِنُوا"
  },
  {
    "id": "15",
    "text": "Helal bellidir, haram bellidir.",
    "source": "Buhârî, Îmân, 39",
    "category": "İlim",
    "arabic": "الْحَلَالُ بَيِّنٌ وَالْحَرَامُ بَيِّنٌ"
  },
  {
    "id": "16",
    "text": "Komşusuna eziyet etmesin.",
    "source": "Buhârî, Edeb, 31",
    "category": "Sosyal Hayat",
    "arabic": "فَلَا يُؤْذِ جَارَهُ"
  },
  {
    "id": "17",
    "text": "Haya imandandır.",
    "source": "Buhârî, Îmân, 16",
    "category": "İman & İhlas",
    "arabic": "الْحَيَاءُ مِنَ الْإِيمَانِ"
  },
  {
    "id": "18",
    "text": "Sözün en doğrusu Allah'ın Kitabıdır.",
    "source": "Müslim, Cum'a, 43",
    "category": "İlim",
    "arabic": "خَيْرَ الْحَدِيثِ كِتَابُ اللَّهِ"
  },
  {
    "id": "19",
    "text": "Kim bir Müslümanın sıkıntısını giderirse Allah da onunkini giderir.",
    "source": "Müslim, Zikir, 38",
    "category": "Sosyal Hayat",
    "arabic": "مَنْ نَفَّسَ عَنْ مُؤْمِنٍ كُرْبَةً"
  },
  {
    "id": "20",
    "text": "Sadaka vermek malı eksiltmez.",
    "source": "Müslim, Birr, 69",
    "category": "Sosyal Hayat",
    "arabic": "مَا نَقَصَتْ صَدَقَةٌ مِنْ مَالٍ"
  },
  {
    "id": "21",
    "text": "Allah katında en sevimli amel, az da olsa devamlı olandır.",
    "source": "Buhârî, Îmân, 32",
    "category": "İbadet",
    "arabic": "أَحَبُّ الْأَعْمَالِ أَدْوَمُهَا"
  },
  {
    "id": "22",
    "text": "Mümin müminin aynasıdır.",
    "source": "Ebû Dâvûd, Edeb, 49",
    "category": "Sosyal Hayat",
    "arabic": "الْمُؤْمِنُ مِرْآةُ الْمُؤْمِنِ"
  },
  {
    "id": "23",
    "text": "Faydasız ilimden sana sığınırım.",
    "source": "Müslim, Zikir, 73",
    "category": "İlim",
    "arabic": "أَعُوذُ بِكَ مِنْ عِلْمٍ لَا يَنْفَعُ"
  },
  {
    "id": "24",
    "text": "Hikmetin başı Allah korkusudur.",
    "source": "Tirmizi, Zühd, 10",
    "category": "İlim",
    "arabic": "رَأْسُ الْحِكْمَةِ مَخَافَةُ اللَّهِ"
  },
  {
    "id": "25",
    "text": "Mümin bir delikten iki kere sokulmaz.",
    "source": "Buhârî, Edeb, 83",
    "category": "Ahlak",
    "arabic": "لَا يُلْدَغُ الْمُؤْمِنُ مِنْ جُحْرٍ"
  },
  {
    "id": "26",
    "text": "Oruç kalkandır.",
    "source": "Buhârî, Savm, 2",
    "category": "İbadet",
    "arabic": "الصِّيَامُ جُنَّةٌ"
  },
  {
    "id": "27",
    "text": "Zenginlik gönül tokluğudur.",
    "source": "Buhârî, Rikâk, 15",
    "category": "Ahlak",
    "arabic": "لَيْسَ الْغِنَى عَنْ كَثْرَةِ الْعَرَضِ"
  },
  {
    "id": "28",
    "text": "Birbirinize kin beslemeyin, haset etmeyin.",
    "source": "Buhârî, Edeb, 57",
    "category": "Sosyal Hayat",
    "arabic": "لَا تَحَاسَدُوا وَلَا تَبَاغَضُوا"
  },
  {
    "id": "29",
    "text": "Allah'a tevekkül et. Vekil olarak Allah yeter.",
    "source": "Ahzâb, 3",
    "category": "İman & İhlas",
    "arabic": "وَتَوَكَّلْ عَلَى اللَّهِ"
  },
  {
    "id": "30",
    "text": "Kim bir iyilik yaparsa, ona on katı verilir.",
    "source": "En'âm, 160",
    "category": "İbadet",
    "arabic": "مَنْ جَاءَ بِالْحَسَنَةِ فَلَهُ عَشْرُ أَمْثَالِهَا"
  },
  {
    "id": "31",
    "text": "Hiç bilenlerle bilmeyenler bir olur mu?",
    "source": "Zümer, 9",
    "category": "İlim",
    "arabic": "هَلْ يَسْتَوِي الَّذِينَ يَعْلَمُونَ"
  },
  {
    "id": "32",
    "text": "Allah size kolaylık diler, zorluk dilemez.",
    "source": "Bakara, 185",
    "category": "İbadet",
    "arabic": "يُرِيدُ اللَّهُ بِكُمُ الْيُسْرَ"
  },
  {
    "id": "33",
    "text": "Yalnız sana ibadet ederiz.",
    "source": "Fâtiha, 5",
    "category": "İbadet",
    "arabic": "إِيَّاكَ نَعْبُدُ وَإِيَّاكَ نَسْتَعِينُ"
  },
  {
    "id": "34",
    "text": "Cennet annelerin ayakları altındadır.",
    "source": "Nesâî, Cihâd, 6",
    "category": "Aile",
    "arabic": "الْجَنَّةُ تَحْتَ أَقْدَامِ الْأُمَّهَاتِ"
  },
  {
    "id": "35",
    "text": "Allah katında en hayırlınız, ailesine en hayırlı olanınızdır.",
    "source": "Tirmizi, Menâkıb, 63",
    "category": "Aile",
    "arabic": "خَيْرُكُمْ خَيْرُكُمْ لِأَهْلِهِ"
  },
  {
    "id": "36",
    "text": "Müminler birbirini sevmede, merhamet etmede bir vücut gibidir.",
    "source": "Buhârî, Edeb, 27",
    "category": "Sosyal Hayat",
    "arabic": "مَثَلُ الْمُؤْمِنِينَ فِي تَوَادِّهِمْ"
  },
  {
    "id": "37",
    "text": "Kıyamet günü kulun hesaba çekileceği ilk şey namazdır.",
    "source": "Tirmizi, Salât, 188",
    "category": "İbadet",
    "arabic": "أَوَّلُ مَا يُحَاسَبُ بِهِ الْعَبْدُ الصَّلَاةُ"
  },
  {
    "id": "38",
    "text": "Kim Allah için sever, Allah için buğzederse imanı kemale ermiştir.",
    "source": "Ebû Dâvûd, Sünnet, 15",
    "category": "İman & İhlas",
    "arabic": "مَنْ أَحَبَّ لِلَّهِ وَأَبْغَضَ لِلَّهِ"
  },
  {
    "id": "39",
    "text": "Şüphesiz her zorlukla beraber bir kolaylık vardır.",
    "source": "İnşirah, 5-6",
    "category": "Zor Anlarda",
    "arabic": "إِنَّ مَعَ الْعُسْرِ يُسْرًا"
  },
  {
    "id": "40",
    "text": "Ey iman edenler! Sabır ve namazla Allah'tan yardım dileyin.",
    "source": "Bakara, 153",
    "category": "İbadet",
    "arabic": "اسْتَعِينُوا بِالصَّبْرِ وَالصَّلَاةِ"
  },
  {
    "id": "41",
    "text": "Allah tövbe edenleri ve temizlenenleri sever.",
    "source": "Bakara, 222",
    "category": "İman & İhlas",
    "arabic": "إِنَّ اللَّهَ يُحِبُّ التَّوَّابِينَ"
  },
  {
    "id": "42",
    "text": "Mümin erkekler ve mümin kadınlar birbirlerinin velileridir.",
    "source": "Tevbe, 71",
    "category": "Sosyal Hayat",
    "arabic": "وَالْمُؤْمِنُونَ وَالْمُؤْمِنَاتُ بَعْضُهُمْ أَوْلِيَاءُ بَعْضٍ"
  },
  {
    "id": "43",
    "text": "Allah'a güven, O sana yeter.",
    "source": "Enfâl, 64",
    "category": "İman & İhlas",
    "arabic": "حَسْبُكَ اللَّهُ"
  },
  {
    "id": "44",
    "text": "Rabbinin adını yücelt.",
    "source": "A'lâ, 1",
    "category": "İbadet",
    "arabic": "سَبِّحِ اسْمَ رَبِّكَ الْأَعْلَى"
  },
  {
    "id": "45",
    "text": "Allah'ı çok zikredin ki kurtuluşa eresiniz.",
    "source": "Cum'a, 10",
    "category": "İbadet",
    "arabic": "وَاذْكُرُوا اللَّهَ كَثِيرًا"
  },
  {
    "id": "46",
    "text": "Allah'ın rahmetinden ümit kesmeyin.",
    "source": "Zümer, 53",
    "category": "İman & İhlas",
    "arabic": "لَا تَقْنَطُوا مِنْ رَحْمَةِ اللَّهِ"
  },
  {
    "id": "47",
    "text": "Rabbinizin mağfiretine koşun.",
    "source": "Âl-i İmrân, 133",
    "category": "İbadet",
    "arabic": "وَسَارِعُوا إِلَى مَغْفِرَةٍ مِنْ رَبِّكُمْ"
  },
  {
    "id": "48",
    "text": "Allah'a borç verin, kat kat ödesin.",
    "source": "Bakara, 245",
    "category": "Sosyal Hayat",
    "arabic": "مَنْ ذَا الَّذِي يُقْرِضُ اللَّهَ قَرْضًا حَسَنًا"
  },
  {
    "id": "49",
    "text": "Namazlarınızı ve orta namazı koruyun.",
    "source": "Bakara, 238",
    "category": "İbadet",
    "arabic": "حَافِظُوا عَلَى الصَّلَوَاتِ"
  },
  {
    "id": "50",
    "text": "Allah sizi analarınızın karnından hiçbir şey bilmezken çıkardı.",
    "source": "Nahl, 78",
    "category": "İlim",
    "arabic": "وَاللَّهُ أَخْرَجَكُمْ مِنْ بُطُونِ أُمَّهَاتِكُمْ"
  },
  {
    "id": "51",
    "text": "Rabbim! İlmimi artır.",
    "source": "Tâhâ, 114",
    "category": "İlim",
    "arabic": "رَبِّ زِدْنِي عِلْمًا"
  },
  {
    "id": "52",
    "text": "Ey Rabbim! Beni ve soyumu namaz kılanlardan eyle.",
    "source": "İbrâhim, 40",
    "category": "Aile",
    "arabic": "رَبِّ اجْعَلْنِي مُقِيمَ الصَّلَاةِ"
  },
  {
    "id": "53",
    "text": "Rabbimiz! Bize dünyada da ahirette de iyilik ver.",
    "source": "Bakara, 201",
    "category": "Dua",
    "arabic": "رَبَّنَا آتِنَا فِي الدُّنْيَا حَسَنَةً"
  },
  {
    "id": "54",
    "text": "Allah'tan bağışlanma dile. Şüphesiz Allah çok bağışlayandır.",
    "source": "Nisâ, 106",
    "category": "İman & İhlas",
    "arabic": "وَاسْتَغْفِرِ اللَّهَ"
  },
  {
    "id": "55",
    "text": "Mümin kardeşini güler yüzle karşılaman sadakadır.",
    "source": "Tirmizi, Birr, 36",
    "category": "Ahlak",
    "arabic": "لَا تَحْقِرَنَّ مِنَ الْمَعْرُوفِ شَيْئًا"
  },
  {
    "id": "56",
    "text": "Rızkın en hayırlısı el emeğiyle kazanılandır.",
    "source": "Buhârî, Büyû, 15",
    "category": "Rızık",
    "arabic": "مَا أَكَلَ أَحَدٌ طَعَامًا قَطُّ خَيْرًا"
  },
  {
    "id": "57",
    "text": "Zandan sakının, zan sözün en yalanıdır.",
    "source": "Buhârî, Edeb, 57",
    "category": "Ahlak",
    "arabic": "إِيَّاكُمْ وَالظَّنَّ"
  },
  {
    "id": "58",
    "text": "Güçlü kimse, öfkelendiğinde kendine hakim olandır.",
    "source": "Buhârî, Edeb, 76",
    "category": "Ahlak",
    "arabic": "لَيْسَ الشَّدِيدُ بِالصُّرَعَةِ"
  },
  {
    "id": "59",
    "text": "Müslüman, insanların elinden ve dilinden emin olduğu kimsedir.",
    "source": "Nesâî, Îmân, 8",
    "category": "Ahlak",
    "arabic": "الْمُسْلِمُ مَنْ سَلِمَ النَّاسُ"
  },
  {
    "id": "60",
    "text": "Allah'ım! Senden hidayet, takva, iffet ve gönül zenginliği isterim.",
    "source": "Müslim, Zikir, 72",
    "category": "Dua",
    "arabic": "اللَّهُمَّ إِنِّي أَسْأَلُكَ الْهُدَى وَالتُّقَى"
  },
  {
    "id": "61",
    "text": "Ey kalpleri evirip çeviren Allah'ım! Kalbimi dinin üzere sabit kıl.",
    "source": "Tirmizi, Kader, 7",
    "category": "Dua",
    "arabic": "يَا مُقَلِّبَ الْقُلُوبِ ثَبِّتْ قَلْبِي"
  },
  {
    "id": "62",
    "text": "Zulmetmekten sakının. Zulüm kıyamet günü karanlıklardır.",
    "source": "Müslim, Birr, 56",
    "category": "Ahlak",
    "arabic": "اتَّقُوا الظُّلْمَ"
  },
  {
    "id": "63",
    "text": "Dünyada bir garip veya yolcu gibi ol.",
    "source": "Buhârî, Rikâk, 3",
    "category": "Zühd",
    "arabic": "كُنْ فِي الدُّنْيَا كَأَنَّكَ غَرِيبٌ"
  },
  {
    "id": "64",
    "text": "Ölmeden önce hayatının, hastalanmadan önce sağlığının kıymetini bil.",
    "source": "Buhârî, Rikâk, 3",
    "category": "Zühd",
    "arabic": "اغْتَنِمْ خَمْسًا قَبْلَ خَمْسٍ"
  },
  {
    "id": "65",
    "text": "Sana şüphe vereni bırak, şüphe vermeyene bak.",
    "source": "Tirmizi, Kıyâme, 60",
    "category": "İlim",
    "arabic": "دَعْ مَا يَرِيبُكَ إِلَى مَا لَا يَرِيبُكَ"
  },
  {
    "id": "66",
    "text": "Allah'a yemin olsun ki mümin, komşusuna eziyet etmez.",
    "source": "Buhârî, Edeb, 31",
    "category": "Sosyal Hayat",
    "arabic": "وَاللَّهِ لَا يُؤْمِنُ"
  },
  {
    "id": "67",
    "text": "Söz taşıyanlar cennete giremez.",
    "source": "Buhârî, Edeb, 50",
    "category": "Ahlak",
    "arabic": "لَا يَدْخُلُ الْجَنَّةَ نَمَّامٌ"
  },
  {
    "id": "68",
