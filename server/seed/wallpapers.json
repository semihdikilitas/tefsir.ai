    "imageUrl": "https://tefsir-ai-api.fly.dev/uploads/1784449364657-77313864.jpg",
    "category": "Duvar Kağıtları",
    "verseText": "Gökleri ve yeri hak ile yarattı. Geceyi gündüze dolar.",
    "surahName": "Zümer Suresi",
    "verseNumbers": "5",
    "isPremium": true,
    "createdAt": "2026-01-01T00:00:00.000Z",
    "thumbnailUrl": "https://tefsir-ai-api.fly.dev/uploads/1784449364657-77313864.jpg"
